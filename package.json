{
  "name": "opensea-print-server",
  "version": "1.6.3",
  "description": "OpenSea Print Server — Conecte impressoras ao OpenSea remotamente",
  "main": "dist/main/main.js",
  "author": {
    "name": "OpenSea ERP",
    "email": "contato@opensea.com.br"
  },
  "license": "PROPRIETARY",
  "scripts": {
    "dev": "concurrently \"npm run dev:main\" \"npm run dev:renderer\"",
    "dev:main": "tsc -p tsconfig.main.json --watch",
    "dev:renderer": "vite dev",
    "build": "npm run build:renderer && npm run build:main",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "vite build",
    "start": "electron dist/main/main.js",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac",
    "dist:linux": "electron-builder --linux",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "npm run build && npx playwright test",
    "typecheck": "tsc -p tsconfig.main.json --noEmit",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@opensea/satellite-contract": "git+https://github.com/OpenSea-ERP/OpenSea-Satellite-Contract.git#v0.1.0",
    "@opensea/satellite-runtime": "git+https://github.com/OpenSea-ERP/OpenSea-Satellite-Runtime.git#v0.3.0",
    "auto-launch": "^5.0.6",
    "electron-log": "^5.1.7",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.2.1",
    "keytar": "^7.9.0",
    "zod": "^3.23.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/auto-launch": "^5.0.5",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/ws": "^8.5.10",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "lucide-react": "^0.468.0",
    "png-to-ico": "^3.0.1",
    "postcss": "^8.4.38",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-electron": "^0.28.0",
    "vitest": "^4.1.4"
  },
  "build": {
    "appId": "com.opensea.print-server",
    "productName": "OpenSea Print Server",
    "artifactName": "OpenSea-PrintServer-Setup-${version}.${ext}",
    "asar": true,
    "asarUnpack": [
      "**/node_modules/keytar/**"
    ],
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "assets/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "assets/icon.icns",
      "category": "public.app-category.utilities"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.png",
      "category": "Utility"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico"
    },
    "publish": {
      "provider": "github",
      "owner": "OpenSea-ERP",
      "repo": "OpenSea-PrintServer-Releases"
    }
  }
}
